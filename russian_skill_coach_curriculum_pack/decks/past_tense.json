        "masc": "был",
        "fem": "была",
        "neut": "было",
        "pl": "были"
      },
      "есть": {
        "masc": "ел",
        "fem": "ела",
        "neut": "ело",
        "pl": "ели"
      }
    },
    "notes": "For я / ты sentences the app must know or ask for the relevant gender before scoring."
  },
